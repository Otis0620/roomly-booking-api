{
  "name": "roomly-booking-api",
  "version": "0.0.1",
  "description": "Hotel booking REST API built with Express, TypeORM, and InversifyJS",
  "type": "commonjs",
  "scripts": {
    "typeorm": "typeorm-ts-node-commonjs",
    "start": "NODE_ENV=production ts-node -r tsconfig-paths/register src/index.ts",
    "dev": "NODE_ENV=development ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/index.ts",
    "test": "npm run test:coverage && npm run test:integration",
    "test:unit": "NODE_ENV=test jest --config jest.unit.config.js",
    "test:integration": "NODE_ENV=test jest --config jest.integration.config.js --runInBand",
    "test:coverage": "NODE_ENV=test jest --config jest.unit.config.js --coverage",
    "migration:generate": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:generate ./src/migrations/${npm_config_name} -d ./src/infrastructure/database/dataSourceCLI.ts",
    "migration:run": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d ./src/infrastructure/database/dataSourceCLI.ts",
    "migration:revert": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:revert -d ./src/infrastructure/database/dataSourceCLI.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint --fix \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/joi": "^17.2.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.0.2",
    "eslint-import-resolver-typescript": "^3.8.3",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jest": "^28.11.0",
    "eslint-plugin-prettier": "^5.2.3",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "prettier": "^3.5.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.6",
    "ts-node": "10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.26.0"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^4.17.2",
    "helmet": "^8.0.0",
    "inversify": "^7.10.2",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.12.0",
    "reflect-metadata": "^0.2.2",
    "tsconfig-paths": "^4.2.0",
    "typeorm": "0.3.20"
  }
}
